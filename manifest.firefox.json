{
  "manifest_version": 3,
  "name": "PSpacer Companion",
  "description": "Enhances spacer.click listing UX by intercepting and filtering sharing API responses in-browser.",
  "version": "0.1.4",
  "action": {
    "default_title": "PSpacer Companion",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://spacer.click/*",
    "https://*.spacer.click/*"
  ],
  "background": {
    "scripts": [
      "src/background/service-worker.js"
    ],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pspacer-companion@local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://spacer.click/*",
        "https://*.spacer.click/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/styles/overlay.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/page-hook.js"
      ],
      "matches": [
        "https://spacer.click/*",
        "https://*.spacer.click/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
