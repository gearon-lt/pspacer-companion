{
  "manifest_version": 3,
  "name": "PSpacer Companion",
  "description": "Enhances spacer.click listing UX by intercepting and filtering sharing API responses in-browser.",
  "version": "0.1.0",
  "action": {
    "default_title": "PSpacer Companion",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/logo.svg",
      "32": "assets/icons/logo.svg"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://spacer.click/*",
    "https://*.spacer.click/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://spacer.click/*",
        "https://*.spacer.click/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/styles/overlay.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/page-hook.js"
      ],
      "matches": [
        "https://spacer.click/*",
        "https://*.spacer.click/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/logo.svg",
    "32": "assets/icons/logo.svg",
    "48": "assets/icons/logo.svg",
    "128": "assets/icons/logo.svg"
  }
}
